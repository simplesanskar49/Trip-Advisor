{
  "name": "trip-architect",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered travel itinerary planner",
  "scripts": {
    "dev:api": "pnpm --filter @trip/api dev",
    "dev:mobile": "pnpm --filter @trip/mobile start",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
